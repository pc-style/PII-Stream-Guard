---
import Layout from "../layouts/Layout.astro";

const title = "PII Stream Guard - live redaction for screen sharing";
const description =
  "A live privacy preview for screen sharing on macOS. Apple Vision OCR finds the emails, phone numbers, and secrets on your screen and redacts them before they reach the stream. Open source, runs locally.";

// Words that cycle through the redaction slot in the headline.
const exposed = ["your email", "your number", "an api key", "a password", "a client"];

const leaks = [
  {
    tag: "the stream",
    name: "two hours, one corner",
    desc: "your email sits in the corner of the frame for a whole live session. <b>by the end it belongs to everyone watching.</b>",
  },
  {
    tag: "the demo",
    name: "the tab bar tell",
    desc: "you screen-share with a client and your personal gmail is right there in the tab bar. <b>the room notices before you do.</b>",
  },
  {
    tag: "the recording",
    name: "fourteen minutes",
    desc: "a customer's phone number is visible for fourteen minutes of a tutorial. <b>you find out after it ships.</b>",
  },
  {
    tag: "the handoff",
    name: "the pasted log",
    desc: "you share a log with an internal token in it. <b>it is now in three slack channels you do not own.</b>",
  },
];

const steps = [
  { n: "01", name: "capture", impl: "ScreenCaptureKit", p: "the main display streams to a pixel buffer continuously. capture never blocks on detection." },
  { n: "02", name: "throttle", impl: "background queue", p: "frames are downscaled and ocr runs five to ten times a second, off the hot path." },
  { n: "03", name: "detect", impl: "Vision OCR", p: "email regex and custom needles run against recognized text, producing per-substring boxes." },
  { n: "04", name: "store", impl: "PIIBox snapshot", p: "a thread-safe snapshot holds the latest boxes, so the preview never waits on detection." },
  { n: "05", name: "redact", impl: "protected preview", p: "the delayed frame is drawn with boxes or a blackout over anything that matched." },
];

const modes = [
  { name: "lockdown", who: "most cautious", p: "accurate ocr, a longer delay buffer, and full blackouts while armed. for demos and recordings you cannot re-shoot.", chips: ["accurate ocr", "blackout", "enhance contrast"], def: false },
  { name: "standard", who: "balanced", p: "fast ocr, a modest delay, and boxes by default. the one you reach for most days.", chips: ["fast ocr", "boxes"], def: true },
  { name: "low-latency", who: "responsive", p: "lower delay and a faster cadence. for live walkthroughs where the preview should track your hands.", chips: ["lowest delay", "faster cadence"], def: false },
];

const presentation = [
  {
    name: "window",
    who: "two monitors",
    p: "the protected preview opens in its own borderless window. capture and redaction run on a delayed buffer, so what you see is frame-accurate. pair it with record for a synced, redacted mov.",
    chips: ["separate window", "frame-accurate", "recordable"],
    def: true,
  },
  {
    name: "overlay",
    who: "one monitor",
    p: "the redaction boxes are drawn straight on top of the real screen as a transparent, click-through layer. no second display needed. detection lags the screen during motion, so treat it as live awareness, not a clean frame — use window + record when the output has to be exact.",
    chips: ["on-screen", "no 2nd monitor", "click-through"],
    def: false,
  },
];

const topo = [
  { name: "local", who: "one mac", p: "the same machine captures the screen, runs ocr, and renders the protected preview. no network, no trust surface." },
  { name: "remote", who: "client + server", p: "a client mac captures frames and sends them to a processing server over a token-authenticated websocket. if the remote path fails, the client fails closed with a black frame." },
];

const cmds = [
  { label: "one-line installer", code: "./scripts/setup.sh" },
  { label: "build from source", code: "swift build -c release\n.build/release/pii-stream watch --mode standard" },
  { label: "on-screen overlay", code: "# one monitor, no preview window\npii-stream watch --mode standard --overlay" },
  { label: "server + client", code: 'pii-stream serve --host 0.0.0.0 --port 8765 \\\n  --token "a-long-random-token"\n\npii-stream watch --remote SERVER:8765 \\\n  --token "a-long-random-token" --mode standard' },
  { label: "scan a static image", code: "pii-stream detect-image --image ./shot.png --json" },
];
---

<Layout title={title} description={description}>
  <header>
    <span class="stamp">classified // until you ship it</span>
    <h1>
      stop showing<br />
      <span class="redact" id="slot" aria-live="polite" data-words={JSON.stringify(exposed)}>your email</span><br />
      on stream.
    </h1>
    <p class="sub">
      a live privacy preview for screen sharing. apple vision ocr finds the
      emails, phone numbers, and secrets on your display, then
      <b>redacts them before they ever reach the stream.</b>
    </p>
    <div class="actions">
      <a class="btn primary" href="#install">read the manual ↓</a>
      <a class="btn ghost" href="https://github.com/pc-style/pii-stream-guard">source</a>
    </div>
    <div class="meta-line">
      <span>macos 14+</span><span class="sep">/</span>
      <span>open source</span><span class="sep">/</span>
      <span>apple vision ocr</span><span class="sep">/</span>
      <span>runs locally</span>
    </div>

    <div class="transcript" data-rv aria-label="live demo: a chat transcript with detected email, phone, and custom string redacted">
      <div class="bar">
        <span>guard preview</span>
        <span class="live">recording</span>
      </div>
      <div class="body">
        <div class="line">
          <div class="who">support</div>
          <div class="b">account on file: <span class="pii">adam.krupa@gmail.com<span class="cover"></span><span class="lab">email</span></span></div>
        </div>
        <div class="line">
          <div class="who">you</div>
          <div class="b">call me back at <span class="pii">+1 (312) 847-1928<span class="cover"></span><span class="lab">phone</span></span> after five.</div>
        </div>
        <div class="line">
          <div class="who">support</div>
          <div class="b">case ref <span class="pii">customer-4821<span class="cover"></span><span class="lab">needle</span></span></div>
        </div>
      </div>
      <div class="foot">
        <span>mode: standard · 8 fps</span>
        <span class="ct">redacted <b>3</b></span>
      </div>
    </div>
    <p class="transcript-cap">apple vision finds an email, a phone number, and a custom string, then covers each before the frame is shown.</p>
  </header>

  <section id="leak">
    <div class="mark"><span class="no">§ 01</span><h2>the exposure</h2></div>
    <div class="ledger">
      {leaks.map((l) => (
        <div class="row" data-rv>
          <span class="tag">{l.tag}</span>
          <span>
            <span class="name">{l.name}</span>
            <span class="desc" set:html={l.desc} />
          </span>
        </div>
      ))}
    </div>
  </section>

  <section id="fix">
    <div class="mark"><span class="no">§ 02</span><h2>the countermeasure</h2></div>
    <div class="directive" data-rv>
      <p class="rule">over-redact is safer than leak.</p>
      <p>
        guard watches your screen, finds what looks like personal data, and
        covers it on a delayed preview before it ever reaches the stream.
        capture and detection are decoupled, so the preview never waits on ocr.
        if anything in the pipeline breaks, the client fails closed with a
        black frame.
      </p>
    </div>
  </section>

  <section id="how">
    <div class="mark"><span class="no">§ 03</span><h2>the procedure</h2></div>
    <div class="proc">
      {steps.map((s) => (
        <div class="step" data-rv>
          <span class="n">{s.n}</span>
          <div>
            <div class="head"><span class="name">{s.name}</span><span class="impl">{s.impl}</span></div>
            <p>{s.p}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section id="modes">
    <div class="mark"><span class="no">§ 04</span><h2>operating modes</h2></div>
    <div class="spec">
      {modes.map((m) => (
        <div class="item" data-rv>
          <div class="top">
            <span class="name">{m.name}</span>
            <span class="who">{m.who}</span>
            {m.def && <span class="badge">default</span>}
          </div>
          <p>{m.p}</p>
          <div class="chips">{m.chips.map((c) => <span>{c}</span>)}</div>
        </div>
      ))}
    </div>
  </section>

  <section id="presentation">
    <div class="mark"><span class="no">§ 05</span><h2>presentation</h2></div>
    <p class="lead">
      where the redacted preview shows up. orthogonal to mode — pick window for a
      frame-accurate buffer, or overlay to draw redaction straight on the screen
      when you only have one display.
    </p>
    <div class="spec">
      {presentation.map((p) => (
        <div class="item" data-rv>
          <div class="top">
            <span class="name">{p.name}</span>
            <span class="who">{p.who}</span>
            {p.def && <span class="badge">default</span>}
          </div>
          <p>{p.p}</p>
          <div class="chips">{p.chips.map((c) => <span>{c}</span>)}</div>
        </div>
      ))}
    </div>
  </section>

  <section id="topology">
    <div class="mark"><span class="no">§ 06</span><h2>deployment</h2></div>
    <div class="spec">
      {topo.map((t) => (
        <div class="item" data-rv>
          <div class="top"><span class="name">{t.name}</span><span class="who">{t.who}</span></div>
          <p>{t.p}</p>
        </div>
      ))}
    </div>
  </section>

  <section id="install">
    <div class="mark"><span class="no">§ 07</span><h2>field install</h2></div>
    <p class="lead">
      macos only. built with swiftpm, no xcode project. the interactive
      installer builds the release binary and offers to start any mode.
    </p>
    <ul class="reqs">
      <li><b>macOS 14</b> or newer</li>
      <li><b>SwiftPM</b> from xcode or the command line tools</li>
      <li><b>Screen Recording</b> permission for your terminal</li>
    </ul>
    {cmds.map((c) => (
      <div class="term" data-rv>
        <div class="cap">
          <span class="label">{c.label}</span>
          <button class="copy" type="button">copy</button>
        </div>
        <pre><code>{c.code}</code></pre>
      </div>
    ))}
  </section>

  <section id="safe">
    <div class="mark"><span class="no">§ 08</span><h2>the safe default</h2></div>
    <div class="directive" data-rv>
      <p class="rule">when in doubt, show nothing.</p>
      <p>
        if anything in the pipeline breaks, you do not get a partial frame with
        pii in it. you get a black frame. the safe default is no picture.
      </p>
    </div>
  </section>

  <Fragment slot="scripts">
    <script>
      // ── headline redaction cycle ──
      // The bar wipes over the word, then -- while fully covered -- the word
      // swaps and the slot width transitions to the next word's width, so the
      // box resizes smoothly behind the bar instead of snapping. Then it lifts.
      (function () {
        const slot = document.getElementById("slot");
        if (!slot) return;
        const parsed = JSON.parse(slot.getAttribute("data-words") || "[]") as string[];
        const list = parsed.length
          ? parsed
          : ["your email", "your number", "an api key", "a password", "a client"];
        if (matchMedia("(prefers-reduced-motion: reduce)").matches) return;

        // Measure each word's rendered width with a hidden clone.
        const ghost = document.createElement("span");
        const cs = getComputedStyle(slot);
        Object.assign(ghost.style, {
          position: "absolute",
          visibility: "hidden",
          whiteSpace: "nowrap",
          font: cs.font,
          fontWeight: cs.fontWeight,
          fontSize: cs.fontSize,
          fontFamily: cs.fontFamily,
          letterSpacing: cs.letterSpacing,
          padding: cs.padding,
        });
        document.body.appendChild(ghost);
        const widthOf = (w: string) => {
          ghost.textContent = w;
          return Math.ceil(ghost.getBoundingClientRect().width);
        };

        let i = 0;
        const setWidth = () => { slot.style.width = widthOf(list[i]) + "px"; };
        slot.textContent = list[0];
        setWidth();
        addEventListener("resize", setWidth);

        const WIPE = 440; // matches CSS transition on the bar + width

        function cycle() {
          slot!.classList.add("clear"); // lift the bar -> reveal word
          setTimeout(() => {
            slot!.classList.remove("clear"); // bar wipes back over
            setTimeout(() => {
              // fully covered now: swap word + resize slot under the bar
              i = (i + 1) % list.length;
              slot!.textContent = list[i];
              setWidth();
            }, WIPE);
          }, 1600);
        }
        cycle();
        setInterval(cycle, 1600 + WIPE * 2 + 400);
      })();

      // ── transcript: momentarily lift one redaction, then snap it back ──
      (function () {
        if (matchMedia("(prefers-reduced-motion: reduce)").matches) return;
        const piis = Array.prototype.slice.call(
          document.querySelectorAll(".transcript .pii")
        ) as HTMLElement[];
        if (!piis.length) return;
        let k = 0;
        function peek() {
          const el = piis[k];
          if (el) {
            el.classList.add("peek");
            setTimeout(() => el.classList.remove("peek"), 750);
          }
          k = (k + 1) % piis.length;
        }
        setInterval(peek, 1900);
      })();

      // ── copy buttons ──
      document.querySelectorAll(".term").forEach((block) => {
        const el = block as HTMLElement;
        const btn = el.querySelector<HTMLButtonElement>(".copy");
        if (!btn) return;
        btn.addEventListener("click", () => {
          const code = el.querySelector("code");
          if (!code || !navigator.clipboard) return;
          navigator.clipboard.writeText(code.textContent ?? "").then(() => {
            btn.textContent = "copied";
            btn.classList.add("ok");
            setTimeout(() => {
              btn.textContent = "copy";
              btn.classList.remove("ok");
            }, 1200);
          });
        });
      });

      // ── reveal on scroll ──
      if (document.documentElement.classList.contains("fx")) {
        const io = new IntersectionObserver(
          (entries, obs) => {
            for (const e of entries) {
              if (!e.isIntersecting) continue;
              e.target.classList.add("in");
              obs.unobserve(e.target);
            }
          },
          { threshold: 0.12, rootMargin: "0px 0px -6% 0px" }
        );
        // stagger siblings within each section group
        document.querySelectorAll<HTMLElement>(".ledger, .proc, .spec").forEach((group) => {
          Array.from(group.querySelectorAll<HTMLElement>("[data-rv]")).forEach((n, i) => {
            n.style.setProperty("--i", String(i));
          });
        });
        document.querySelectorAll<HTMLElement>("[data-rv]").forEach((node) => {
          io.observe(node);
        });

        // Safety net: reveal anything already in view once loaded, so
        // above-the-fold content never waits on an intersection event.
        const revealInView = () => {
          document.querySelectorAll<HTMLElement>("[data-rv]:not(.in)").forEach((n) => {
            const r = n.getBoundingClientRect();
            if (r.top < innerHeight && r.bottom > 0) n.classList.add("in");
          });
        };
        revealInView();
        addEventListener("load", () => setTimeout(revealInView, 200));
      }
    </script>
  </Fragment>
</Layout>
